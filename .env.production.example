# ATHENA — production environment template (Phase 5, W1).
#
# Copy to `.env.production` and fill in real values from your secret store.
# NEVER commit the filled-in file. `.env.production` is git-ignored.
# Generate strong secrets, e.g.:  openssl rand -hex 32
# All values below are placeholders — the stack refuses to start on the
# development JWT default (ADR-0019 / Settings.ensure_safe_for_environment).

# ---- runtime posture -------------------------------------------------------
ATHENA_ENV=production
ATHENA_PILOT_MODE=true              # W6: decision-support pilot (read-only, human-in-the-loop)
ATHENA_DOMAIN=athena.example.com    # used by certbot + Grafana root URL
WEB_CONCURRENCY=2                   # uvicorn workers per api container
ATHENA_IMAGE_TAG=latest             # pin to the release SHA in real deploys

# ---- managed data stores (Render + Neon + Upstash) -------------------------
# When deploying to Render with Neon + Upstash, set these two directly (they
# supersede the compose-internal POSTGRES_PASSWORD/REDIS_PASSWORD below, which
# are only used by the self-hosted docker-compose.prod.yml stack).
# Neon: use the DIRECT (non-pooled) endpoint and require SSL.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxx.aws.neon.tech/athena?sslmode=require
# Upstash: rediss:// gives TLS automatically.
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# ---- initial admin (optional; idempotent seed on first deploy) -------------
# If set, one ADMIN user is created on first boot, then never again.
ATHENA_SEED_ADMIN_EMAIL=admin@example.com
ATHENA_SEED_ADMIN_PASSWORD=CHANGE_ME_8+chars

# ---- secrets (REQUIRED — no defaults in production) ------------------------
JWT_SECRET=CHANGE_ME_min_32_random_chars_openssl_rand_hex_32
# POSTGRES_PASSWORD / REDIS_PASSWORD are only for the self-hosted compose stack
# (docker-compose.prod.yml). On Render+Neon+Upstash, use DATABASE_URL/REDIS_URL
# above instead and you can ignore these two.
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password
GRAFANA_ROOT_URL=https://grafana.athena.example.com

# ---- tokens & limits (optional; sane defaults shown) -----------------------
ACCESS_TOKEN_TTL=900                # 15 min
REFRESH_TOKEN_TTL=1209600           # 14 days
RATE_LIMIT_PER_MINUTE=240
AUTH_RATE_LIMIT_PER_MINUTE=20

# ---- TLS / Let's Encrypt ---------------------------------------------------
LETSENCRYPT_EMAIL=ops@example.com

# ---- data provider (W5 — Alpha Vantage adapter) ----------------------------
# Credentials via environment ONLY (never hardcoded, never logged).
ALPHAVANTAGE_API_KEY=CHANGE_ME_provider_api_key

# ---- LLM gateway (optional; explain/summarize only — never decisions) ------
# LLM_API_KEY=CHANGE_ME_if_research_copilot_enabled
