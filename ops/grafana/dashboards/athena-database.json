{
  "title": "ATHENA — Database (PostgreSQL)",
  "uid": "athena-database",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PostgreSQL up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
      ] } },
      "targets": [{ "expr": "pg_up", "legendFormat": "pg_up" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active backends",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(pg_stat_database_numbackends{datname=\"athena\"})", "legendFormat": "backends" }]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Cache hit ratio",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [
        { "color": "red", "value": null }, { "color": "orange", "value": 0.9 }, { "color": "green", "value": 0.98 }
      ] } } },
      "targets": [{ "expr": "sum(rate(pg_stat_database_blks_hit{datname=\"athena\"}[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit{datname=\"athena\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=\"athena\"}[5m])), 1)", "legendFormat": "hit ratio" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Deadlocks (total)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "sum(pg_stat_database_deadlocks{datname=\"athena\"})", "legendFormat": "deadlocks" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Transactions / s (commit vs rollback)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname=\"athena\"}[5m])", "legendFormat": "commit" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname=\"athena\"}[5m])", "legendFormat": "rollback" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tuples returned / fetched / s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "rate(pg_stat_database_tup_returned{datname=\"athena\"}[5m])", "legendFormat": "returned" },
        { "expr": "rate(pg_stat_database_tup_fetched{datname=\"athena\"}[5m])", "legendFormat": "fetched" }
      ]
    }
  ]
}
