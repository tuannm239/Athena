{
  "title": "ATHENA — Redis (cache)",
  "uid": "athena-redis",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redis up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
      ] } },
      "targets": [{ "expr": "redis_up", "legendFormat": "redis_up" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connected clients",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "redis_connected_clients", "legendFormat": "clients" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory used",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "used" }]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Keyspace hit ratio",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [
        { "color": "red", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "green", "value": 0.9 }
      ] } } },
      "targets": [{ "expr": "sum(rate(redis_keyspace_hits_total[5m])) / clamp_min(sum(rate(redis_keyspace_hits_total[5m])) + sum(rate(redis_keyspace_misses_total[5m])), 1)", "legendFormat": "hit ratio" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Commands processed / s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "cmd/s" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Hits vs misses / s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "rate(redis_keyspace_hits_total[5m])", "legendFormat": "hits" },
        { "expr": "rate(redis_keyspace_misses_total[5m])", "legendFormat": "misses" }
      ]
    }
  ]
}
