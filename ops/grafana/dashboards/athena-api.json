{
  "title": "ATHENA API",
  "uid": "athena-api",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (path) (rate(athena_http_requests_total[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 latency by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(athena_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (non-2xx share)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(athena_http_requests_total{status!~\"2..\"}[5m])) / sum(rate(athena_http_requests_total[5m]))",
          "legendFormat": "error share"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Requests / s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(athena_http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    }
  ]
}
