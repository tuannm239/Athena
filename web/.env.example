# ATHENA web (Next.js) — environment template.
#
# Copy to `.env.local` for local development:  cp .env.example .env.local
# In production these are set in the Vercel dashboard, NOT committed.
#
# The web app is a thin client: it holds NO secrets. Its only configuration
# is where to reach the backend. All /api/* requests are proxied server-side
# (next.config.mjs rewrites) to ATHENA_API_URL, so the browser only ever
# talks to its own origin — no CORS, no API keys in the bundle.

# Base URL of the Athena backend API (FastAPI on Render).
# Local:      http://localhost:8000
# Production: https://<your-service>.onrender.com
ATHENA_API_URL=http://localhost:8000
