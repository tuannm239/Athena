# ATHENA web (Next.js) — production environment (Vercel).
#
# Set these in the Vercel dashboard → Project → Settings → Environment
# Variables (Production scope). Do NOT commit real values. The web app holds
# no secrets; the single required variable is the backend URL it proxies to.

# Public HTTPS URL of the Athena backend on Render.
ATHENA_API_URL=https://athena-api.onrender.com
