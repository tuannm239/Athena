# =============================================================================
# ATHENA — environment template (development & self-hosted)
# =============================================================================
# Copy to `.env` for local work:  cp .env.example .env
# For a real deployment (Vercel + Render + Neon + Upstash) see
# `.env.production.example` and DEPLOYMENT_GUIDE.md. Never commit a filled-in
# `.env` — it is git-ignored. Generate secrets with:  openssl rand -hex 32
#
# Every variable Athena reads is listed below, grouped by concern. Defaults
# shown are the development defaults baked into backend/infrastructure/config.py;
# they are safe for localhost only. Production refuses to boot on the dev JWT
# secret (ADR-0019).
# =============================================================================

# ---- BACKEND · runtime posture ---------------------------------------------
ATHENA_ENV=development                 # development | production
ATHENA_PILOT_MODE=false                # true = read-only decision-support pilot
WEB_CONCURRENCY=2                      # uvicorn workers (ignored in dev reload)

# ---- DATABASE (PostgreSQL / Neon) ------------------------------------------
# Local docker-compose default shown. Neon example (note sslmode=require):
#   postgresql+psycopg://USER:PWD@ep-xxx.aws.neon.tech/athena?sslmode=require
DATABASE_URL=postgresql+psycopg://athena:athena@localhost:5432/athena

# ---- REDIS (cache & idempotency / Upstash) ---------------------------------
# Local default shown. Upstash example (TLS): rediss://default:PWD@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ---- ANALYTICS SNAPSHOTS (DuckDB, local dir) -------------------------------
DUCKDB_DIR=data/snapshots

# ---- AUTHENTICATION & SECURITY ---------------------------------------------
# 32+ random chars in production (openssl rand -hex 32). Dev default is unsafe.
JWT_SECRET=dev-only-secret-change-me
ACCESS_TOKEN_TTL=900                    # access token lifetime, seconds (15 min)
REFRESH_TOKEN_TTL=1209600              # refresh token lifetime, seconds (14 days)
RATE_LIMIT_PER_MINUTE=240             # per-client request budget
AUTH_RATE_LIMIT_PER_MINUTE=20         # tighter budget on /auth/* endpoints

# ---- INITIAL ADMIN (optional, idempotent seed on deploy) -------------------
# If both are set, scripts/seed.py creates one ADMIN user on first boot and
# does nothing thereafter. Leave unset to register the first user via the UI.
# ATHENA_SEED_ADMIN_EMAIL=admin@example.com
# ATHENA_SEED_ADMIN_PASSWORD=change-me-8+chars

# ---- DATA PROVIDER (optional; credentials via env ONLY, never logged) ------
# ALPHAVANTAGE_API_KEY=your_provider_api_key

# ---- LLM GATEWAY (optional; explain/summarize only — never decisions) ------
# LLM_API_KEY=your_key_if_research_copilot_enabled

# =============================================================================
# FRONTEND (Next.js, web/) — set these in Vercel, not here. See web/.env.example
# =============================================================================
# ATHENA_API_URL=http://localhost:8000   # backend base URL the web app proxies to
